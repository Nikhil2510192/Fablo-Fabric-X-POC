# Generated by fablo-fabric-x-poc
# Network: <%= config.network.name %>
# DO NOT EDIT - re-run generate.ts to update

services:

  # ── Certificate Authority ─────────────────────────────
<% config.network.organizations.forEach(function(org) { %>
  ca.<%= org.domain %>:
    image: <%= org.ca.image %>
    container_name: ca.<%= org.domain %>
    environment:
      - FABRIC_CA_HOME=/etc/hyperledger/fabric-ca-server
      - FABRIC_CA_SERVER_CA_NAME=ca-<%= org.name.toLowerCase() %>
      - FABRIC_CA_SERVER_PORT=<%= org.ca.port %>
      - FABRIC_CA_SERVER_TLS_ENABLED=<%= config.fabricX.tls %>
    ports:
      - "<%= org.ca.port %>:<%= org.ca.port %>"
    volumes:
      - <%= org.name.toLowerCase() %>_ca_data:/etc/hyperledger/fabric-ca-server
    networks:
      - <%= config.network.name %>
healthcheck:
      test: ["CMD", "sh", "-c", "wget -q -O- http://localhost:<%= org.ca.port %>/cainfo || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    restart: unless-stopped
<% }) %>

  # ── Endorser (Fabric Peer) ────────────────────────────
<% config.network.organizations.forEach(function(org) { %>
  endorser.<%= org.domain %>:
    image: hyperledger/fabric-peer:2.5.15
    container_name: endorser.<%= org.domain %>
    environment:
      - CORE_PEER_ID=endorser.<%= org.domain %>
      - CORE_PEER_ADDRESS=endorser.<%= org.domain %>:7041
      - CORE_PEER_LOCALMSPID=<%= org.name %>MSP
      - CORE_PEER_TLS_ENABLED=<%= config.fabricX.tls %>
      - FABRIC_LOGGING_SPEC=INFO
    networks:
      - <%= config.network.name %>
    depends_on:
      ca.<%= org.domain %>:
        condition: service_healthy
    restart: unless-stopped
<% }) %>

  # ── Arma Orderer Components ───────────────────────────

  # Router — accepts transactions from clients
  orderer-router.<%= config.network.name %>:
    image: <%= config.network.orderer.image %>
    container_name: orderer-router.<%= config.network.name %>
    command: router --config=/etc/arma/router_node_config.yaml
    ports:
      - "<%= config.network.orderer.ports.router %>:<%= config.network.orderer.ports.router %>"
    volumes:
      - ./arma-configs/router_node_config.yaml:/etc/arma/router_node_config.yaml:ro
    networks:
      - <%= config.network.name %>
    depends_on:
<% config.network.organizations.forEach(function(org) { %>
      ca.<%= org.domain %>:
        condition: service_healthy
<% }) %>
    restart: unless-stopped

  # Batcher — bundles transactions into batches
  orderer-batcher.<%= config.network.name %>:
    image: <%= config.network.orderer.image %>
    container_name: orderer-batcher.<%= config.network.name %>
    command: batcher --config=/etc/arma/batcher_node_config.yaml
    ports:
      - "<%= config.network.orderer.ports.batcher %>:<%= config.network.orderer.ports.batcher %>"
    volumes:
      - ./arma-configs/batcher_node_config.yaml:/etc/arma/batcher_node_config.yaml:ro
      - orderer_batcher_data:/var/hyperledger/production
    networks:
      - <%= config.network.name %>
    depends_on:
      - orderer-router.<%= config.network.name %>
    restart: unless-stopped

  # Consenter — runs BFT consensus
  orderer-consenter.<%= config.network.name %>:
    image: <%= config.network.orderer.image %>
    container_name: orderer-consenter.<%= config.network.name %>
    command: consensus --config=/etc/arma/consenter_node_config.yaml
    ports:
      - "<%= config.network.orderer.ports.consenter %>:<%= config.network.orderer.ports.consenter %>"
    volumes:
      - ./arma-configs/consenter_node_config.yaml:/etc/arma/consenter_node_config.yaml:ro
      - orderer_consenter_data:/var/hyperledger/production
    networks:
      - <%= config.network.name %>
    depends_on:
      - orderer-batcher.<%= config.network.name %>
    restart: unless-stopped

  # Assembler — creates ordered blocks, serves to committers
  orderer-assembler.<%= config.network.name %>:
    image: <%= config.network.orderer.image %>
    container_name: orderer-assembler.<%= config.network.name %>
    command: assembler --config=/etc/arma/assembler_node_config.yaml
    ports:
      - "<%= config.network.orderer.ports.assembler %>:<%= config.network.orderer.ports.assembler %>"
    volumes:
      - ./arma-configs/assembler_node_config.yaml:/etc/arma/assembler_node_config.yaml:ro
      - orderer_assembler_data:/var/hyperledger/production
    networks:
      - <%= config.network.name %>
    depends_on:
      - orderer-consenter.<%= config.network.name %>
    restart: unless-stopped

  # ── Committer (includes DB + sidecar) ────────────────
<% config.network.organizations.forEach(function(org) { %>
  committer.<%= org.domain %>:
    image: <%= org.committer.image %>
    container_name: committer.<%= org.domain %>
    command: run db committer
    environment:
      - SC_SIDECAR_ORDERER_ENDPOINT=orderer-assembler.<%= config.network.name %>:<%= config.network.orderer.ports.assembler %>
      - SC_SIDECAR_ORDERER_CHANNEL_ID=<%= config.network.name %>
    ports:
      - "<%= org.committer.port %>:<%= org.committer.port %>"
    networks:
      - <%= config.network.name %>
    depends_on:
      - orderer-assembler.<%= config.network.name %>
    restart: unless-stopped
<% }) %>

# ── Networks ──────────────────────────────────────────
networks:
  <%= config.network.name %>:
    driver: bridge

# ── Volumes ───────────────────────────────────────────
volumes:
  orderer_batcher_data:
  orderer_consenter_data:
  orderer_assembler_data:
<% config.network.organizations.forEach(function(org) { %>
  <%= org.name.toLowerCase() %>_ca_data:
<% }) %>